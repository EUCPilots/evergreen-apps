{
    "Name": "Foxit PDF Reader",
    "Source": "https://www.foxitsoftware.com/pdf-reader/",
    "Get": {
        "Update": {
            "InitialUri": "https://www.foxit.com/products/catalog/",
            "CookieHost": "https://www.foxit.com",
            "Uri": "https://www.foxit.com/foxit-api/form/showDownloadForm/?form_id=download-reader&language=ML&platform=Windows&package_type=&lang=en-us&fresh=1"
        },
        "Download": {
            "Uri": "https://www.foxit.com/foxit-api/form/latest/?product=Foxit-Reader&platform=Windows&version=#version&package_type=#filetype&language=ML",
            "Language": "Multi-Language"
        }
    },
    "Install": {
        "Setup": "FoxitReader*.msi",
        "Physical": {
            "Arguments": "DESKTOP_SHORTCUT=\"0\" MAKEDEFAULT=\"0\" VIEWINBROWSER=\"0\" LAUNCHCHECKDEFAULT=\"0\" AUTO_UPDATE=\"1\" /passive /norestart /qn",
            "PostInstall": []
        },
        "Virtual": {
            "Arguments": "DESKTOP_SHORTCUT=\"0\" MAKEDEFAULT=\"0\" VIEWINBROWSER=\"0\" LAUNCHCHECKDEFAULT=\"0\" AUTO_UPDATE=\"0\" /passive /norestart /qn",
            "PostInstall": []
        }
    }
}