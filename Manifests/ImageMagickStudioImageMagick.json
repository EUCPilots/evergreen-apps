			"ReplaceText": "#version"
		}
	},
	"Install": {
		"Setup": "ImageMagick*.exe",
		"Physical": {
			"Arguments": "",
			"PostInstall": []
		},
		"Virtual": {
			"Arguments": "",
			"PostInstall": []
		}
	}
}
