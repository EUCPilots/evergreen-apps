{
	"Name": "Podman",
	"Source": "https://podman.io/",
	"Get": {
		"Uri": "https://api.github.com/repos/podman-container-tools/podman/releases/latest",
		"MatchVersion": "(\\d+(\\.\\d+){1,4}).*",
		"MatchFileTypes": "\\.exe$"
	},
	"Install": {
		"Setup": "podman-*.exe",
		"Physical": {
			"Arguments": "/install /quiet /norestart",
			"PostInstall": []
		},
		"Virtual": {
			"Arguments": "",
			"PostInstall": []
		}
	}
}
