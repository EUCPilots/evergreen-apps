{
	"Name": "Slack",
	"Source": "https://slack.com/intl/en-gb/help/articles/212475728-Deploy-Slack-for-Windows",
	"Get": {
		"Update": {
			"Uri": ""
		},
		"Download": {
			"Uri": [
				"https://slack.com/api/desktop.latestRelease?arch=arm64&variant=msix&redirect=true",
				"https://slack.com/api/desktop.latestRelease?arch=x64&variant=msix&redirect=true",
				"https://slack.com/api/desktop.latestRelease?arch=x64&variant=exe&redirect=true"
			]
		},
		"MatchVersion": "(\\d+(\\.\\d+){1,4})"
	},
	"Install": {
		"Setup": "Slack.*.msi",
		"Physical": {
			"Arguments": "/quiet /norestart",
			"PostInstall": []
		},
		"Virtual": {
			"Arguments": "/quiet /norestart",
			"PostInstall": []
		}
	}
}