{
	"Name": "jrsoftware InnoSetup",
	"Source": "https://www.innosetup.com",
	"Get": {
		"Uri": "https://api.github.com/repos/jrsoftware/issrc/releases/latest",
		"MatchVersion": "(\\d+(\\.\\d+){1,4}).*",
		"MatchFileTypes": "\\.exe$|\\.msi$"
	},
	"Install": {
		"Setup": "innosetup*.exe",
		"Physical": {
			"Arguments": "/VERYSILENT",
			"PostInstall": []
		},
		"Virtual": {
			"Arguments": "/VERYSILENT",
			"PostInstall": []
		}
	}
}
